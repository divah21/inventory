{
  "name": "interplumb-inventory-backend",
  "version": "1.0.0",
  "description": "Dynamic inventory management API for Interplumb (multi-project, multi-warehouse).",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/migrator.js up",
    "db:migrate:undo": "node src/migrator.js down",
    "db:migrate:status": "node src/migrator.js status",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:drop && sequelize-cli db:create && npm run db:migrate && sequelize-cli db:seed:all",
    "import:excel": "node src/importers/excelImporter.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "sequelize-cli": "^6.6.2",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
